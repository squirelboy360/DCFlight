import 'package:dcf_primitives/dcf_primitives.dart';
import 'package:dcflight/dcflight.dart';

class DCFGo extends StatefulComponent {
  @override
  VDomNode render() {
    // Create references to control navigation
    final homeStackRef = useRef<StackNavigatorRef?>(null);
    final settingsStackRef = useRef<StackNavigatorRef?>(null);
    final detailsModalRef = useRef<ModalRef?>(null);
    
    return view(
      style: StyleSheet(
        backgroundColor: Colors.grey[100],
      ),
      layout: LayoutProps(
        flex: 1,
      ),
      children: [
        // Main tab navigator - using factory function
        tabNavigator(
          ref: TabNavigatorRef('mainTabs'),
          initialIndex: 0,
          tintColor: '#007AFF',
          unselectedTintColor: '#8E8E93',
          tabs: [
            // Home Tab with Stack Navigator
            TabItem(
              id: 'homeTab',
              title: 'Home',
              icon: 'system:house',
              component: createHomeTab(homeStackRef),
            ),
            // Profile Tab
            TabItem(
              id: 'profileTab',
              title: 'Profile',
              icon: 'system:person',
              component: createProfileTab(),
            ),
            // Settings Tab with Stack Navigator
            TabItem(
              id: 'settingsTab',
              title: 'Settings',
              icon: 'system:gear',
              component: createSettingsTab(settingsStackRef),
            ),
          ],
        ),
        
        // Details modal that can be shown from any tab - using factory function
        modal(
          ref: ModalRef('detailsModal'),
          presentationStyle: 'pageSheet',
          transitionStyle: 'coverVertical',
          content: createDetailsModal(detailsModalRef),
        ),
      ],
    );
  }
  
      ],
    );
  }
  
  // Create Home tab with Stack Navigator
  VDomNode createHomeTab(RefObject<StackNavigatorRef?> homeStackRef) {
    final stackRef = StackNavigatorRef('homeStack');
    homeStackRef.current = stackRef;
    
    return StackNavigator(
      ref: stackRef,
      initialRouteId: 'homeMain',
      barStyle: StackNavigationBarStyle.largeTitles,
      routes: [
        // Home main screen
        StackRoute(
          id: 'homeMain',
          title: 'Home',
          component: createHomeMainScreen(homeStackRef),
        ),
        // Details screen
        StackRoute(
          id: 'homeDetails',
          title: 'Details',
          component: createDetailsScreen(homeStackRef),
        ),
      ],
    );
  }
  
  // Create Home Main Screen
  VDomNode createHomeMainScreen(RefObject<StackNavigatorRef?> homeStackRef) {
    return scrollView(
      scrollViewProps: ScrollViewProps(
        showsIndicator: true,
        clipsToBounds: true,
      ),
      style: StyleSheet(),
      layout: LayoutProps(
        flex: 1,
        padding: 16,
        alignItems: YogaAlign.center,
      ),
      children: [
        image(
          imageProps: ImageProps(source: 'assets/logo_bg.png'),
          layout: LayoutProps(
            width: 150,
            height: 150,
            padding: 8,
            marginBottom: 16,
          ),
          style: StyleSheet(
            borderRadius: 50,
          ),
        ),
        text(
          content: 'Hello, DCF Go!',
          layout: LayoutProps(marginBottom: 16),
          textProps: TextProps(fontSize: 24, color: Colors.black),
        ),
        button(
          onPress: () {
            // Navigate to details screen using stack navigator
            homeStackRef.value?.push('homeDetails');
          },
          layout: LayoutProps(width: 200, marginBottom: 16),
          buttonProps: ButtonProps(title: 'Go to Details'),
        ),
      ],
    );
  }
  
  // Create Details Screen
  VDomNode createDetailsScreen(RefObject<StackNavigatorRef?> stackRef) {
    return view(
      style: StyleSheet(
        backgroundColor: Colors.white,
      ),
      layout: LayoutProps(
        flex: 1,
        padding: 16,
        alignItems: YogaAlign.center,
        justifyContent: YogaJustifyContent.center,
      ),
      children: [
        text(
          content: 'Details Screen',
          layout: LayoutProps(marginBottom: 16),
          textProps: TextProps(fontSize: 24, color: Colors.black),
        ),
        text(
          content: 'This is a nested screen in the stack navigation',
          layout: LayoutProps(marginBottom: 24, width: 250),
          textProps: TextProps(fontSize: 16, color: Colors.grey[700], textAlign: TextAlign.center),
        ),
        button(
          onPress: () {
            // Pop back to previous screen
            stackRef.value?.pop();
          },
          layout: LayoutProps(width: 200),
          buttonProps: ButtonProps(title: 'Go Back'),
        ),
      ],
    );
  }
  
  // Create Profile Tab
  VDomNode createProfileTab() {
    return view(
      style: StyleSheet(
        backgroundColor: Colors.grey[200],
      ),
      layout: LayoutProps(
        flex: 1,
        padding: 16,
        alignItems: YogaAlign.center,
        justifyContent: YogaJustifyContent.center,
      ),
      children: [
        image(
          imageProps: ImageProps(source: 'https://picsum.photos/seed/profile/200/200'),
          layout: LayoutProps(
            width: 120,
            height: 120,
            marginBottom: 24,
          ),
          style: StyleSheet(
            borderRadius: 60,
          ),
        ),
        text(
          content: 'User Profile',
          layout: LayoutProps(marginBottom: 8),
          textProps: TextProps(fontSize: 24, fontWeight: FontWeight.bold, color: Colors.black),
        ),
        text(
          content: 'john.doe@example.com',
          layout: LayoutProps(marginBottom: 32),
          textProps: TextProps(fontSize: 16, color: Colors.grey[600]),
        ),
        button(
          onPress: () {
            // Show modal with details using the existing ref from parent component
            ModalRef('detailsModal').present();
          },
          layout: LayoutProps(width: 200),
          buttonProps: ButtonProps(title: 'Show Profile Details'),
        ),
      ],
    );
  }
  
  // Create Settings Tab with Stack Navigator
  VDomNode createSettingsTab(RefObject<StackNavigatorRef?> settingsStackRef) {
    return StackNavigator(
      ref: settingsStackRef.value = StackNavigatorRef('settingsStack'),
      initialRouteId: 'settingsMain',
      routes: [
        // Settings main screen
        StackRoute(
          id: 'settingsMain',
          title: 'Settings',
          component: createSettingsMainScreen(settingsStackRef),
        ),
        // Preferences screen
        StackRoute(
          id: 'preferences',
          title: 'Preferences',
          component: createPreferencesScreen(settingsStackRef),
        ),
        // About screen
        StackRoute(
          id: 'about',
          title: 'About',
          component: createAboutScreen(settingsStackRef),
        ),
      ],
    );
  }
  
  // Create Settings Main Screen
  VDomNode createSettingsMainScreen(RefObject<StackNavigatorRef?> settingsStackRef) {
    return scrollView(
      scrollViewProps: ScrollViewProps(
        showsIndicator: true,
      ),
      layout: LayoutProps(
        flex: 1,
        padding: 16,
      ),
      children: [
        // Preferences Option
        view(
          layout: LayoutProps(
            height: 60,
            marginBottom: 1,
            flexDirection: YogaFlexDirection.row,
            alignItems: YogaAlign.center,
            paddingHorizontal: 16,
          ),
          style: StyleSheet(
            backgroundColor: Colors.white,
          ),
          on: {
            'onPress': () {
              settingsStackRef.value?.push('preferences');
            },
          },
          children: [
            text(
              content: 'Preferences',
              textProps: TextProps(fontSize: 16, color: Colors.black),
            ),
          ],
        ),
        
        // About Option
        view(
          layout: LayoutProps(
            height: 60,
            marginBottom: 1,
            flexDirection: YogaFlexDirection.row,
            alignItems: YogaAlign.center,
            paddingHorizontal: 16,
          ),
          style: StyleSheet(
            backgroundColor: Colors.white,
          ),
          on: {
            'onPress': () {
              settingsStackRef.value?.push('about');
            },
          },
          children: [
            text(
              content: 'About',
              textProps: TextProps(fontSize: 16, color: Colors.black),
            ),
          ],
        ),
      ],
    );
  }
  
  // Create Preferences Screen
  VDomNode createPreferencesScreen(RefObject<StackNavigatorRef?> stackRef) {
    return view(
      style: StyleSheet(
        backgroundColor: Colors.white,
      ),
      layout: LayoutProps(
        flex: 1,
        padding: 16,
        alignItems: YogaAlign.center,
        justifyContent: YogaJustifyContent.center,
      ),
      children: [
        text(
          content: 'Preferences',
          layout: LayoutProps(marginBottom: 24),
          textProps: TextProps(fontSize: 24, color: Colors.black),
        ),
        button(
          onPress: () {
            stackRef.value?.pop();
          },
          layout: LayoutProps(width: 200),
          buttonProps: ButtonProps(title: 'Go Back'),
        ),
      ],
    );
  }
  
  // Create About Screen
  VDomNode createAboutScreen(RefObject<StackNavigatorRef?> stackRef) {
    return view(
      style: StyleSheet(
        backgroundColor: Colors.white,
      ),
      layout: LayoutProps(
        flex: 1,
        padding: 16,
        alignItems: YogaAlign.center,
        justifyContent: YogaJustifyContent.center,
      ),
      children: [
        text(
          content: 'About DCF Go',
          layout: LayoutProps(marginBottom: 16),
          textProps: TextProps(fontSize: 24, color: Colors.black),
        ),
        text(
          content: 'Version 1.0.0',
          layout: LayoutProps(marginBottom: 8),
          textProps: TextProps(fontSize: 16, color: Colors.grey[700]),
        ),
        text(
          content: '© 2025 DCFlight Framework',
          layout: LayoutProps(marginBottom: 32),
          textProps: TextProps(fontSize: 14, color: Colors.grey[600]),
        ),
        button(
          onPress: () {
            stackRef.value?.pop();
          },
          layout: LayoutProps(width: 200),
          buttonProps: ButtonProps(title: 'Go Back'),
        ),
      ],
    );
  }
  
  // Create Details Modal
  VDomNode createDetailsModal(RefObject<ModalRef?> modalRef) {
    return view(
      style: StyleSheet(
        backgroundColor: Colors.white,
      ),
      layout: LayoutProps(
        padding: 24,
        alignItems: YogaAlign.center,
      ),
      children: [
        text(
          content: 'Profile Details',
          layout: LayoutProps(marginBottom: 24),
          textProps: TextProps(fontSize: 24, fontWeight: FontWeight.bold, color: Colors.black),
        ),
        text(
          content: 'John Doe',
          layout: LayoutProps(marginBottom: 8),
          textProps: TextProps(fontSize: 18, color: Colors.black),
        ),
        text(
          content: 'Account created: May 10, 2024',
          layout: LayoutProps(marginBottom: 32),
          textProps: TextProps(fontSize: 16, color: Colors.grey[700]),
        ),
        button(
          onPress: () {
            modalRef.value?.dismiss();
          },
          layout: LayoutProps(width: 200),
          buttonProps: ButtonProps(title: 'Close'),
        ),
      ],
    );
  }
}



